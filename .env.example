# Active API base URL. Pick the one matching your environment.
# Staging:    https://api.staging.fitcall.me/api/v1
# Production: https://api.fitcall.me/api/v1
EXPO_PUBLIC_API_BASE_URL=https://api.staging.fitcall.me/api/v1

# Google Sign-In OAuth 2.0 client IDs from Google Cloud Console.
# - Web Client ID is REQUIRED on Android to retrieve an idToken (the SDK needs it
#   for the audience, even though we never run on web).
# - iOS Client ID is optional unless you target iOS.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# ── Android release signing ──────────────────────────────────────────────
# Consumed by plugins/withReleaseSigning.js during `expo prebuild`: it writes
# these into android/gradle.properties and (optionally) materialises the
# keystore file, so release builds are signed with your key. NOT prefixed with
# EXPO_PUBLIC_, so they are never bundled into the app — they only configure the
# native build. Leave blank to fall back to debug signing.
#
# Provide the keystore one of two ways:
#   (a) Point KEYSTORE_PATH at an existing .keystore file (local dev), or
#   (b) Set KEYSTORE_BASE64 to the base64 of the file (CI) — it is decoded to
#       KEYSTORE_PATH on prebuild. Generate with:
#         certutil -encode fitcall-release.keystore fitcall-release.keystore.base64
ANDROID_RELEASE_KEYSTORE_PATH=./fitcall-release.keystore
ANDROID_RELEASE_KEYSTORE_BASE64=
ANDROID_RELEASE_KEY_ALIAS=fitcall
ANDROID_RELEASE_KEYSTORE_PASSWORD=
ANDROID_RELEASE_KEY_PASSWORD=
