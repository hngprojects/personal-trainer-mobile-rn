# Active API base URL. Pick the one matching your environment.
# Staging:    https://api.staging.fitcall.me/api/v1
# Production: https://api.fitcall.me/api/v1
EXPO_PUBLIC_API_BASE_URL=https://api.staging.fitcall.me/api/v1

# Google Sign-In OAuth 2.0 client IDs from Google Cloud Console.
# - Web Client ID is REQUIRED on Android to retrieve an idToken (the SDK needs it
#   for the audience, even though we never run on web).
# - iOS Client ID is optional unless you target iOS.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
