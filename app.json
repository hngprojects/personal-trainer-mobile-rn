{
  "expo": {
    "name": "FITCALL",
    "slug": "fitcall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-app.png",
    "scheme": "fitcall",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.emerj.fitcall",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "edgeToEdgeEnabled": true,
      "package": "net.emerj.fitcall"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/logo.png",
          "imageWidth": 200
        }
      ],
      "expo-font",
      "@react-native-google-signin/google-signin",
      "expo-apple-authentication",
      "expo-video",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow FITCALL to use your location to personalize your profile."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FITCALL to access your photos so you can set a profile picture.",
          "cameraPermission": "Allow FITCALL to use your camera so you can take a profile picture."
        }
      ],
      "expo-image",
      "react-native-iap",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-dontwarn expo.modules.core.interfaces.services.KeepAwakeManager"
          }
        }
      ],
      "./plugins/withAndroidArchitectures",
      "./plugins/withAndroidVersion",
      "./plugins/withReleaseSigning"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
