{
  "name": "react-native-starter",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "author": {
    "name": "Jeffery Orazulike",
    "email": "jeffery@logickoder.dev",
    "url": "https://logickoder.dev"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "husky"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "@react-native-async-storage/async-storage": "@react-native-async-storage/async-storage/jest/async-storage-mock",
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint --max-warnings 0 --fix",
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.80.5",
    "axios": "^1.9.0",
    "expo": "~55.0.19",
    "expo-av": "^16.0.8",
    "expo-constants": "~55.0.15",
    "expo-font": "~55.0.7",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-location": "~55.1.10",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.16",
    "expo-video": "~55.0.16",
    "react": "19.2.0",
    "react-hook-form": "^7.57.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.4",
    "zod": "^3.24.4",
    "zustand": "^5.0.5"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "@tootallnate/once@<3.0.1": ">=3.0.1"
    }
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest-expo": "^55.0.16",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
